# MongoDB Database Configuration
MONGODB_URI="mongodb+srv://username:password@cluster.example.mongodb.net"
DB_NAME="database_name"

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001

# CORS
FRONTEND_URL="http://localhost:3000"

# S3 Config
AWS_S3_ENDPOINT="https://s3.tebi.io"
AWS_S3_REGION="global"
AWS_S3_BUCKET="your-bucket-name"
AWS_S3_ACCESS_KEY_ID="your-access-key-id"
AWS_S3_SECRET_ACCESS_KEY="your-secret-access-key"

# Email Configuration (for password reset)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
CLIENT_URL="http://localhost:3000"