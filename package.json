{
  "name": "plannova-project",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "install": "cd client && npm install && cd ../server && npm install",
    "install:client": "cd client && npm install",
    "install:server": "cd server && npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" --names \"server,client\" --prefix-colors \"yellow,cyan\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "status": "echo \"🚀 Backend API: http://localhost:3000\" && echo \"🌐 Frontend: http://localhost:3000\"",
    "build": "concurrently \"npm run build:server\" \"npm run build:client\" --names \"server,client\" --prefix-colors \"yellow,cyan\"",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "husky": "^8.0.3"
  }
}
